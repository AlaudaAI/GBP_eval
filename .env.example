# Bearer that unlocks the app for the dev team.
# All developers enter this same value via TokenGate on first visit.
SHARED_API_TOKEN=

# Upstash Redis — auto-injected on Vercel via Marketplace.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Anthropic — enables LLM-generated recommendations and the action plan.
# Falls back to deterministic templates if missing.
ANTHROPIC_API_KEY=

# GBP data sources. Outscraper covers ~12/14 checks; Places is fallback.
OUTSCRAPER_API_KEY=
GOOGLE_PLACES_API_KEY=
